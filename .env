# ============================================================
# Adversarial Game Experiment — Environment Configuration
# ============================================================

# ── API Keys ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=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
GEMINI_API_KEY=AIzaSyCBUVAxQhNg5tQHenLrTachmRjiv5rLoZM
# ── Active Provider: runs by default when no -p flag given ──
ACTIVE_PROVIDER=gemini

# ── Model Selection ──
# OPENAI:    gpt-4o-mini | gpt-4o | gpt-5-nano
OPENAI_MODEL=gpt-5-nano
# ANTHROPIC: claude-haiku-4-20250414 | claude-sonnet-4-20250514
ANTHROPIC_MODEL=claude-haiku-4-20250414
# GROQ:      llama-3.1-8b-instant | llama-3.3-70b-versatile
GROQ_MODEL=llama-3.1-8b-instant
# GEMINI (your paid subscription):
#   gemini-3.1-flash-lite-preview   fastest, what you are using now
#   gemini-3.1-flash-preview        balanced
#   gemini-3.1-pro-preview          best quality
GEMINI_MODEL=gemini-2.5-pro

# ── Speed Settings ──
# 360 total conditions = 4 games x 9 opponents x 10 episodes
# Each condition = ~39 API calls across all 5 stages
# Full run at 10 eps ≈ 14,000 calls  (~4 hrs on paid tier)
# Balanced  at 3 eps  ≈ 4,200 calls  (~75 min on paid tier)
# Quick test at 1 ep  ≈ 1,400 calls  (~25 min on paid tier)
DEFAULT_EPISODES=10

# Auto-generate plots after every run
AUTO_PLOT=true

# ── Paid Subscription Rate Settings ──
# You have a paid subscription — no throttling needed at all.
# These high values disable any waiting between requests.
GEMINI_RPM=1000
GEMINI_TPM=10000000

# ── Google Cloud / Vertex AI (Model Garden — $300 free credits) ──
# 4 project IDs — one per terminal/game for parallel runs (separate quota pools)
GCP_PROJECT_ID_1=braintotextgc
GCP_PROJECT_ID_2=finetuning-429617
GCP_PROJECT_ID_3=hallowed-zoo-440401-p6
GCP_PROJECT_ID_4=project-aca8d913-c933-4cce-92f

# Vertex AI — Llama 4 (OpenAI-compatible, region: us-east5)
VERTEX_LLAMA_MODEL=meta/llama-4-maverick-17b-128e-instruct-maas
VERTEX_LLAMA_LOCATION=us-east5

# Vertex AI — Anthropic Claude (uses AnthropicVertex SDK, region: us-east5)
VERTEX_ANTHROPIC_MODEL=claude-sonnet-4-5
VERTEX_ANTHROPIC_LOCATION=us-east5

# Vertex AI — DeepSeek (OpenAI-compatible, global endpoint)
VERTEX_DEEPSEEK_MODEL=deepseek-ai/deepseek-v3.2-maas
VERTEX_DEEPSEEK_LOCATION=global

# Auth: run once before using Vertex providers:
#   gcloud auth application-default login
